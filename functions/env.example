# Firebase Functions 環境變數配置範例
# 複製此文件為 .env 並填入實際值

# === 必要設置 ===

# Google Sheets 試算表 ID
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# === 效能調優 ===

# 記憶體使用警告閾值 (MB)
MEMORY_LIMIT_WARNING=50
MEMORY_LIMIT_CRITICAL=100

# API 調用限制
HEALTH_CHECK_TIMEOUT=15000
SHEET_CHECK_INTERVAL=30000
MAX_PROCESSING_TIME=45000
API_RATE_LIMIT_WINDOW=60000

# === 安全設置 ===

# 鎖定超時時間 (毫秒)
LOCK_TIMEOUT=30000

# === 監控設置 ===

# 統計資料保留數量
MAX_PROCESSING_TIMES=50
MAX_INSTANCE_IDS=500

# === 開發設置 ===

# 環境標識
NODE_ENV=development

# 調試模式
DEBUG=false

# 日誌級別 (error, warn, info, debug)
LOG_LEVEL=info

# === 可選設置 ===

# 自定義服務帳戶金鑰路徑 (如不使用預設)
# GOOGLE_APPLICATION_CREDENTIALS=./src/config/google-credentials.json

# 時區設置
TZ=Asia/Taipei

# === 說明 ===
#
# 1. GOOGLE_SPREADSHEET_ID 從 Google Sheets URL 中取得
#    https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
#
# 2. 記憶體限制建議值：
#    - WARNING: 50MB (輕量使用)
#    - CRITICAL: 100MB (重度使用前告警)
#
# 3. 超時設置建議值：
#    - HEALTH_CHECK: 15秒 (避免 GCP Functions 超時)
#    - SHEET_CHECK: 30秒 (避免 API 配額濫用)
#    - PROCESSING: 45秒 (確保在 60秒限制內完成)
#
# 4. 環境設置：
#    - development: 開發環境
#    - staging: 測試環境
#    - production: 生產環境