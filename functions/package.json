{
  "name": "functions",
  "scripts": {
    "build": "tsc && cp -r src/config lib/",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "deploy:dev": "../deploy-config.sh dev",
    "deploy:staging": "../deploy-config.sh staging",
    "deploy:prod": "../deploy-config.sh prod",
    "logs": "firebase functions:log",
    "logs:tail": "firebase functions:log --tail",
    "test:health": "curl -f http://localhost:5001/market-calculator/us-central1/api/health || echo 'Health check failed'",
    "setup:env": "cp env.example .env && echo 'Please edit .env with your configuration'"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1",
    "googleapis": "^150.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.23",
    "firebase-functions-test": "^3.1.0",
    "typescript": "^5.7.3"
  },
  "private": true
}
